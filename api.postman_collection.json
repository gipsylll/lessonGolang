{
  "info": {
    "name": "Go JWT Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login as user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login — invalid credentials",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrong\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET /users/1 — found",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1"
          }
        },
        {
          "name": "GET /users/999 — not found",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/999"
          }
        },
        {
          "name": "GET /users/abc — invalid id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/abc"
          }
        },
        {
          "name": "POST /users — valid",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\",\n  \"email\": \"bob@example.com\"\n}"
            }
          }
        },
        {
          "name": "POST /users — missing email",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\"\n}"
            }
          }
        },
        {
          "name": "POST /users — invalid email",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\",\n  \"email\": \"not-an-email\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "GET /notes — authenticated",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notes",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET /notes — no token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notes"
          }
        },
        {
          "name": "POST /notes — create",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/notes",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My note\",\n  \"body\": \"Hello world\"\n}"
            }
          }
        },
        {
          "name": "DELETE /notes/1 — admin only",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/notes/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "DELETE /notes/1 — forbidden (login as user first)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/notes/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
